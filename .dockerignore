# ============================================================================
# Docker Ignore File
# ============================================================================
# This file specifies which files and directories should be excluded from
# the Docker build context. Excluding unnecessary files reduces build time
# and image size.
# ============================================================================

# ============================================================================
# Dependencies
# ============================================================================
# node_modules will be installed during Docker build
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log
# package-lock.json is needed for npm ci in Dockerfile

# ============================================================================
# Environment & Configuration
# ============================================================================
# Never include sensitive environment files in Docker images
.env
.env.*
!.env.example

# ============================================================================
# Git & Version Control
# ============================================================================
.git
.gitignore
.gitattributes

# ============================================================================
# Netlify (Not needed for standalone server)
# ============================================================================
netlify/
netlify.toml
.netlify

# ============================================================================
# Documentation & Planning
# ============================================================================
README.md
LICENSE
plans/
docs/

# ============================================================================
# Sample Files (Not needed in production)
# ============================================================================
samples/

# ============================================================================
# IDE & Editor Files
# ============================================================================
.vscode
.idea
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Docker Files (Don't include Docker files in the image)
# ============================================================================
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.*.yml

# ============================================================================
# CI/CD & Testing
# ============================================================================
.github
.gitlab-ci.yml
.travis.yml
.circleci
coverage/
.nyc_output
test/
tests/
*.test.js
*.spec.js

# ============================================================================
# Build Artifacts & Temporary Files
# ============================================================================
dist/
build/
tmp/
temp/
*.log
*.pid
*.seed
*.pid.lock

# ============================================================================
# OS Files
# ============================================================================
Thumbs.db
.DS_Store
